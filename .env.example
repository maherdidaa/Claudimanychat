# --- Database ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_DB=messenger_automation
DATABASE_URL=postgresql://app:app_password@localhost:5432/messenger_automation?schema=public

# --- Redis / Queue ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Token encryption (32 bytes, hex or base64) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# --- Facebook App ---
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_WEBHOOK_VERIFY_TOKEN=change_me_verify_token
FB_GRAPH_API_VERSION=v19.0
FB_GRAPH_API_BASE_URL=https://graph.facebook.com

# --- App ---
API_PORT=4000
NODE_ENV=development
